{
  "name": "mini-front",
  "description": "Mini HealthLearn frontend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --hostname front.hl.local",
    "build": "next build",
    "start": "next start",
    "test": "jest"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "autoprefixer": "10.4.21",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "classnames": "^2.5.1",
    "jose": "^6.0.12",
    "uuid": "^9.0.1",
    "next": "^15.5.9",
    "nuqs": "^2.8.9",
    "postcss": "8.5.6",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.12",
    "@types/uuid": "^9.0.8",
    "ts-jest": "^29.1.0",
    "@types/node": "24.0.14",
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.9",
    "prisma": "^6.15.0",
    "ts-node": "^10.9.2"
  },
  "resolutions": {
    "@types/react": "19.1.11",
    "@types/react-dom": "19.1.7"
  },
  "jest": {
    "testEnvironment": "jest-fixed-jsdom",
    "extensionsToTreatAsEsm": [
      ".ts",
      ".tsx"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@project/(.*)$": "<rootDir>/node_modules/$1"
    },
    "testRegex": ".*\\.spec\\.(ts|tsx)$",
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "esnext",
            "moduleResolution": "bundler",
            "jsx": "react-jsx"
          }
        }
      ]
    }
  }
}
